<!DOCTYPE html>
<html>
<head>
<title>SOFRENOR - TRS</title>
<link rel="stylesheet" href="css/style.css">
</head>

<body>

<header>
<img src="images/logo.png">
<h2>Suivi TRS - SOFRENOR</h2>
</header>

<div class="container">

<div class="card">
<h3>Connexion</h3>

<input id="user" placeholder="Nom utilisateur">
<input id="pass" type="password" placeholder="Mot de passe">

<select id="role">
<option value="op">Opérateur</option>
<option value="resp">Responsable</option>
</select>

<button onclick="login()">Se connecter</button>

</div>

</div>

<script>
function login(){
let role = document.getElementById("role").value;

if(role=="op"){
window.location.href="saisie.html";
}else{
window.location.href="dashboard.html";
}
}
</script>

</body>
</html>
